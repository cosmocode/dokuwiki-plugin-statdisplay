{
    "name": "szymach/c-pchart",
    "license": "GPL-3.0-only",
    "type": "library",
    "description": "Port of \"pChart\" library into PHP 8+",
    "keywords": ["pchart", "pChart", "statistics", "charts", "CpChart", "c-pChart"],
    "homepage": "https://github.com/szymach/c-pchart",
    "authors": [
        {
            "name": "Jean-Damien Pogolotti",
            "homepage": "http://www.pchart.net",
            "role": "Creator of the original pChart library"
        },
        {
            "name": "Piotr Szymaszek",
            "homepage": "https://github.com/szymach",
            "role": "Developer of the CpChart wrapper package"
        }
    ],
    "autoload": {
        "psr-4": { "CpChart\\": "src/" },
        "files": ["constants.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\CpChart\\Unit\\": [
                "tests/unit/"
            ],
            "Tests\\CpChart\\Support\\": [
                "tests/_support/"
            ]
        }
    },
    "require": {
        "php": "^8.0",
        "ext-gd": "*"
    },
    "require-dev" : {
        "codeception/codeception": "^5.3",
        "phpunit/phpunit": "^12.4",
        "squizlabs/php_codesniffer": "^4.0",
        "codeception/module-asserts": "^3.2",
        "codeception/module-filesystem": "^3.0",
        "phpstan/phpstan": "^2.1"
    },
    "config": {
        "bin-dir": "vendor/bin"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "4.0.x-dev",
            "3.1": "3.1.x-dev",
            "3.0": "3.0.x-dev",
            "2.0": "2.0.x-dev"
        }
    },
    "scripts": {
        "sniffer": "vendor/bin/phpcs",
        "codecept": "vendor/bin/codecept run",
        "stan_7": "vendor/bin/phpstan analyze -c phpstan_7.neon",
        "stan_max": "vendor/bin/phpstan analyze -c phpstan_max.neon"
    }
}
