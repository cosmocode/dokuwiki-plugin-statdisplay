        {
            "name": "Chris Schuld",
            "email": "chris@chrisschuld.com",
            "homepage": "https://chrisschuld.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "cbschuld\\": "src/"
        },
        "files": ["legacy/Browser.php"]
    },
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "support": {
        "issues": "https://github.com/cbschuld/Browser.php/issues",
